@page "/"
@using KanvasKata.Features.Editor.Models
@using KanvasKata.Features.Editor.Services
@inject CanvasStateService State
@inject IJSRuntime JS
@implements IDisposable

<div class="editor-layout">
    <div class="editor-main"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onmouseleave="OnMouseUp">

        <div class="editor-toolbar">
            <span class="toolbar-label">Tambah</span>
            <button class="toolbar-btn" @onclick="AddText">
                <span class="toolbar-btn-icon">T</span> Text
            </button>
            <button class="toolbar-btn" @onclick="ToggleAddImage">
                <span class="toolbar-btn-icon">⬜</span> Image
            </button>
            @if (_showAddImage)
            {
                <div class="toolbar-image-form">
                    <input class="toolbar-image-input" type="text" placeholder="Masukkan URL gambar..."
                           @bind="_newImageUrl" @bind:event="oninput"
                           @onkeydown="OnImageInputKeyDown" />
                    <button class="toolbar-btn toolbar-btn-primary" @onclick="AddImage">Tambah</button>
                    <button class="toolbar-btn" @onclick="() => _showAddImage = false">Batal</button>
                </div>
            }

            <div class="toolbar-divider"></div>

            <div class="toolbar-export-group">
                <button class="toolbar-btn toolbar-btn-export" @onclick="() => ExportPng(1)" disabled="@_exporting">
                    @if (_exporting && _exportScale == 1)
                    {
                        <span>Exporting…</span>
                    }
                    else
                    {
                        <span>⬇ Export 1×</span>
                    }
                </button>
                <button class="toolbar-btn toolbar-btn-export" @onclick="() => ExportPng(2)" disabled="@_exporting">
                    @if (_exporting && _exportScale == 2)
                    {
                        <span>Exporting…</span>
                    }
                    else
                    {
                        <span>⬇ Export 2×</span>
                    }
                </button>
            </div>

            <div class="toolbar-divider"></div>

            <span class="toolbar-label">Kanvas</span>
            <div class="toolbar-canvas-size">
                <input class="toolbar-size-input" type="number" min="100" max="3000"
                       value="@State.CanvasWidth"
                       @onchange="e => OnCanvasSizeChange(e, isWidth: true)" />
                <span class="toolbar-size-sep">×</span>
                <input class="toolbar-size-input" type="number" min="100" max="3000"
                       value="@State.CanvasHeight"
                       @onchange="e => OnCanvasSizeChange(e, isWidth: false)" />
                <span class="toolbar-size-unit">px</span>
            </div>
        </div>

        <div class="editor-canvas" @onclick="OnCanvasClick">
            @if (!State.Items.Any())
            {
                <div class="canvas-empty">
                    <div class="canvas-empty-icon">✦</div>
                    <p>Kanvas kosong. Tambah elemen dari toolbar di atas.</p>
                </div>
            }
            <div class="kanvas" style="width: @(State.CanvasWidth)px; height: @(State.CanvasHeight)px;" @onclick:stopPropagation>
                @foreach (var item in State.Items)
                {
                    if (item is ImageItem img)
                    {
                        var isSelected = State.SelectedItem?.Id == img.Id;
                        <div class="kanvas-item @(isSelected ? "selected" : "")"
                             style="@ImgWrapperStyle(img)"
                             @onmousedown="e => OnItemMouseDown(e, img)"
                             @onclick:stopPropagation>
                            <img src="@img.Src" alt="@img.Alt" style="@ImgStyle(img)" />
                            @if (isSelected)
                            {
                                @foreach (var handle in ResizeHandles)
                                {
                                    var h = handle;
                                    <div class="resize-handle resize-handle-@h"
                                         @onmousedown="e => OnResizeMouseDown(e, img, h)"
                                         @onmousedown:stopPropagation></div>
                                }
                            }
                        </div>
                    }
                    else if (item is TextItem text)
                    {
                        <div class="kanvas-item kanvas-item-text @Selected(text) @(_editingItemId == text.Id ? "editing" : "")"
                             style="left: @(text.X)px; top: @(text.Y)px;"
                             @onmousedown="e => OnItemMouseDown(e, text)"
                             @ondblclick="() => StartEdit(text)"
                             @ondblclick:stopPropagation
                             @onclick:stopPropagation>
                            @if (_editingItemId == text.Id)
                            {
                                <textarea class="text-edit-input" style="@TextStyle(text)"
                                          value="@text.Text"
                                          @oninput="e => { text.Text = e.Value?.ToString() ?? text.Text; State.NotifyChange(); }"
                                          @onblur="StopEdit"
                                          @onkeydown="OnEditKeyDown"
                                          @onmousedown:stopPropagation
                                          @ref="_editRef"></textarea>
                            }
                            else
                            {
                                <span style="@TextStyle(text)">@text.Text</span>
                            }
                        </div>
                    }
                }

                @if (State.SelectedItem is not null && _editingItemId is null)
                {
                    var sel = State.SelectedItem;
                    var barY = (int)Math.Max(4, sel.Y - 34);
                    <div class="item-layer-bar"
                         style="left: @((int)sel.X)px; top: @(barY)px;"
                         @onmousedown:stopPropagation
                         @onclick:stopPropagation>
                        @LayerBarContent(sel)
                    </div>
                }
            </div>
        </div>
    </div>

    <PropertiesSidebar />
</div>

@code {
    private static readonly string[] ResizeHandles = ["nw", "n", "ne", "w", "e", "sw", "s", "se"];

    private bool _exporting;
    private int _exportScale;
    private bool _showAddImage;
    private string _newImageUrl = string.Empty;

    // Move drag
    private CanvasItem? _dragging;
    private double _lastMouseX, _lastMouseY;
    private bool _isDragging;

    // Resize drag
    private ImageItem? _resizingImg;
    private string? _resizeHandle;

    private Guid? _editingItemId;
    private ElementReference _editRef;
    private bool _shouldFocusEdit;

    protected override void OnInitialized() => State.OnChange += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string Selected(CanvasItem item) =>
        State.SelectedItem?.Id == item.Id ? "selected" : "";

    private RenderFragment LayerBarContent(CanvasItem item) => __builder =>
    {
        <button class="layer-btn" title="Ke depan" @onclick="() => State.BringToFront(item)">⬆</button>
        <button class="layer-btn" title="Maju satu layer" @onclick="() => State.BringForward(item)">↑</button>
        <span class="layer-index">@(State.IndexOf(item) + 1)/@State.Items.Count</span>
        <button class="layer-btn" title="Mundur satu layer" @onclick="() => State.SendBackward(item)">↓</button>
        <button class="layer-btn" title="Ke belakang" @onclick="() => State.SendToBack(item)">⬇</button>
    };

    // ── Export ──

    private async Task ExportPng(int scale)
    {
        _exporting = true;
        _exportScale = scale;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("kanvasExport.exportPng", ".kanvas", "kanvaskata.png", scale);
        _exporting = false;
        _exportScale = 0;
    }

    // ── Toolbar ──

    private void OnCanvasSizeChange(ChangeEventArgs e, bool isWidth)
    {
        if (!int.TryParse(e.Value?.ToString(), out var val)) return;
        if (isWidth) State.ResizeCanvas(val, State.CanvasHeight);
        else State.ResizeCanvas(State.CanvasWidth, val);
    }

    private void AddText()
    {
        var offset = State.Items.Count * 20 % 120;
        State.AddItem(new TextItem { X = 40 + offset, Y = 40 + offset });
    }

    private void ToggleAddImage()
    {
        _showAddImage = !_showAddImage;
        _newImageUrl = string.Empty;
    }

    private void AddImage()
    {
        if (string.IsNullOrWhiteSpace(_newImageUrl)) return;
        var offset = State.Items.Count * 20 % 80;
        State.AddItem(new ImageItem { Src = _newImageUrl.Trim(), X = 40 + offset, Y = 40 + offset });
        _newImageUrl = string.Empty;
        _showAddImage = false;
    }

    private void OnImageInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddImage();
        if (e.Key == "Escape") _showAddImage = false;
    }

    // ── Canvas click ──

    private void OnCanvasClick()
    {
        _editingItemId = null;
        State.SelectItem(null);
    }

    // ── Move drag ──

    private void OnItemMouseDown(MouseEventArgs e, CanvasItem item)
    {
        if (_editingItemId == item.Id) return;
        State.SelectItem(item);
        _dragging = item;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
        _isDragging = false;
    }

    // ── Resize drag ──

    private void OnResizeMouseDown(MouseEventArgs e, ImageItem img, string handle)
    {
        // Init height when dragging a handle that affects height
        if (img.Height == 0 && handle is not ("e" or "w"))
            img.Height = (int)(img.Width * 0.75f);

        _resizingImg = img;
        _resizeHandle = handle;
        _dragging = null;
        _lastMouseX = e.ClientX;
        _lastMouseY = e.ClientY;
        _isDragging = true;
    }

    // ── Mouse move (shared) ──

    private void OnMouseMove(MouseEventArgs e)
    {
        var dx = e.ClientX - _lastMouseX;
        var dy = e.ClientY - _lastMouseY;

        if (_resizingImg is not null && _resizeHandle is not null)
        {
            ApplyResize(_resizingImg, _resizeHandle, dx, dy);
            _lastMouseX = e.ClientX;
            _lastMouseY = e.ClientY;
            StateHasChanged();
            return;
        }

        if (_dragging is null) return;
        if (!_isDragging && (Math.Abs(dx) > 3 || Math.Abs(dy) > 3))
            _isDragging = true;
        if (_isDragging)
        {
            _dragging.X += (float)dx;
            _dragging.Y += (float)dy;
            _lastMouseX = e.ClientX;
            _lastMouseY = e.ClientY;
            StateHasChanged();
        }
    }

    private void ApplyResize(ImageItem img, string handle, double dx, double dy)
    {
        switch (handle)
        {
            case "e":
                img.Width = Math.Max(20, (int)(img.Width + dx));
                break;
            case "w":
                var wW = (int)(img.Width - dx);
                if (wW >= 20) { img.Width = wW; img.X += (float)dx; }
                break;
            case "s":
                img.Height = Math.Max(20, (int)(img.Height + dy));
                break;
            case "n":
                var nH = (int)(img.Height - dy);
                if (nH >= 20) { img.Height = nH; img.Y += (float)dy; }
                break;
            case "se":
                img.Width = Math.Max(20, (int)(img.Width + dx));
                img.Height = Math.Max(20, (int)(img.Height + dy));
                break;
            case "sw":
                var swW = (int)(img.Width - dx);
                if (swW >= 20) { img.Width = swW; img.X += (float)dx; }
                img.Height = Math.Max(20, (int)(img.Height + dy));
                break;
            case "ne":
                img.Width = Math.Max(20, (int)(img.Width + dx));
                var neH = (int)(img.Height - dy);
                if (neH >= 20) { img.Height = neH; img.Y += (float)dy; }
                break;
            case "nw":
                var nwW = (int)(img.Width - dx);
                if (nwW >= 20) { img.Width = nwW; img.X += (float)dx; }
                var nwH = (int)(img.Height - dy);
                if (nwH >= 20) { img.Height = nwH; img.Y += (float)dy; }
                break;
        }
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        if (_resizingImg is not null) State.NotifyChange();
        _dragging = null;
        _isDragging = false;
        _resizingImg = null;
        _resizeHandle = null;
    }

    // ── Inline edit ──

    private void StartEdit(TextItem text)
    {
        _editingItemId = text.Id;
        _shouldFocusEdit = true;
    }

    private void StopEdit()
    {
        _editingItemId = null;
        State.NotifyChange();
    }

    private void OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") StopEdit();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusEdit)
        {
            _shouldFocusEdit = false;
            try { await _editRef.FocusAsync(); } catch { }
        }
    }

    // ── Style helpers ──

    private static string ImgWrapperStyle(ImageItem img)
    {
        var s = $"left: {img.X}px; top: {img.Y}px; width: {img.Width}px;";
        if (img.Height > 0) s += $" height: {img.Height}px;";
        return s;
    }

    private static string ImgStyle(ImageItem img) =>
        img.Height > 0
            ? "width: 100%; height: 100%; object-fit: fill; display: block; pointer-events: none;"
            : "width: 100%; height: auto; display: block; pointer-events: none;";

    private static string TextStyle(TextItem t)
    {
        var style = $"font-family: '{t.FontFamily}', sans-serif; font-size: {t.FontSize}px; color: {t.Color}; text-align: {t.Align}; white-space: pre-wrap;";
        if (t.StrokeWidth > 0)
            style += $" -webkit-text-stroke: {t.StrokeWidth}px {t.StrokeColor};";
        return style;
    }

    public void Dispose() => State.OnChange -= OnStateChanged;
}
